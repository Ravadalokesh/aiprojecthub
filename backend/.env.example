MONGODB_URI=mongodb://localhost:27017/projectmanagement
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE=7d
PORT=5000
NODE_ENV=development

# OpenRouter AI Configuration
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your_api_key_here
# Model options: openrouter/auto, gpt-4, gpt-3.5-turbo, claude-2, etc.
OPENROUTER_MODEL=openrouter/auto

# Redis (for caching and task queue)
REDIS_URL=redis://localhost:6379

# Frontend URL (legacy single-origin setting)
FRONTEND_URL=http://localhost:5173

# Preferred CORS setting for production deployments
# Comma-separated list. Wildcards like https://*.vercel.app are supported.
ALLOWED_ORIGINS=http://localhost:5173

# API rate limiting
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
